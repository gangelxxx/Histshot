<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:l="clr-namespace:Histshot.Localization"
        x:Class="Histshot.Views.SettingsWindow"
        Title="{l:Localize Settings_Title}"
        Width="500"
        Height="320"
        CanResize="False"
        RequestedThemeVariant="Dark"
        Background="#181818"
        WindowStartupLocation="CenterScreen">

    <Window.Styles>
        <Style Selector="TextBlock.label">
            <Setter Property="Foreground" Value="#EDEDED" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="TextBlock.sublabel">
            <Setter Property="Foreground" Value="#9A9A9A" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style Selector="CheckBox">
            <Setter Property="Foreground" Value="#EDEDED" />
            <Setter Property="FontSize" Value="13" />
        </Style>
<Style Selector="Button.primary">
            <Setter Property="Background" Value="#0078D4" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="20,8" />
        </Style>
        <Style Selector="Button.primary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#106EBE" />
        </Style>
        <Style Selector="Button.secondary">
            <Setter Property="Background" Value="#2C2C2C" />
            <Setter Property="Foreground" Value="#EDEDED" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="20,8" />
        </Style>
        <Style Selector="Button.secondary:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#3A3A3A" />
        </Style>
        <Style Selector="TextBox.hotkeyBox">
            <Setter Property="Background" Value="#2C2C2C" />
            <Setter Property="Foreground" Value="#EDEDED" />
            <Setter Property="BorderBrush" Value="#3C3C3C" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Height" Value="32" />
        </Style>
        <Style Selector="TextBox.hotkeyBox:disabled /template/ Border">
            <Setter Property="Background" Value="#1E1E1E" />
        </Style>
        <Style Selector="TextBox.hotkeyBox:disabled">
            <Setter Property="Foreground" Value="#555555" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,Auto">
        <TabControl Grid.Row="0" Background="#181818">

            <!-- ── General ─────────────────────────────────── -->
            <TabItem Header="{l:Localize Tab_General}">
                <StackPanel Margin="24,20" Spacing="22">

                    <CheckBox x:Name="AutostartCheckBox"
                              Content="{l:Localize LaunchAtStartup}" />

                    <StackPanel Spacing="7">
                        <TextBlock Classes="sublabel" Text="{l:Localize Language}" />
                        <ComboBox x:Name="LanguageComboBox"
                                  Width="230"
                                  HorizontalAlignment="Left" />
                    </StackPanel>

                </StackPanel>
            </TabItem>

            <!-- ── Hotkeys ─────────────────────────────────── -->
            <TabItem Header="{l:Localize Tab_Hotkeys}">
                <StackPanel Margin="24,20" Spacing="14">

                    <!-- Primary hotkey -->
                    <Grid ColumnDefinitions="Auto,*,190" ColumnSpacing="12">
                        <CheckBox Grid.Column="0"
                                  x:Name="PrimaryHotkeyEnabled"
                                  IsCheckedChanged="PrimaryHotkeyEnabled_Changed" />
                        <TextBlock Grid.Column="1" Classes="label" Text="{l:Localize PrimaryHotkey}" />
                        <TextBox Grid.Column="2"
                                 Classes="hotkeyBox"
                                 x:Name="PrimaryHotkeyBox" />
                    </Grid>

                    <!-- Quick save full screen -->
                    <Grid ColumnDefinitions="Auto,*,190" ColumnSpacing="12">
                        <CheckBox Grid.Column="0"
                                  x:Name="QuickSaveEnabled"
                                  IsCheckedChanged="QuickSaveEnabled_Changed" />
                        <TextBlock Grid.Column="1" Classes="label" Text="{l:Localize QuickSaveFullScreen}" />
                        <TextBox Grid.Column="2"
                                 Classes="hotkeyBox"
                                 x:Name="QuickSaveBox" />
                    </Grid>

                </StackPanel>
            </TabItem>

        </TabControl>

        <!-- Bottom buttons -->
        <StackPanel Grid.Row="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="16,0,16,16"
                    Spacing="8">
            <Button Classes="secondary" Content="{l:Localize Cancel}" Click="Cancel_Click" />
            <Button Classes="primary" Content="{l:Localize Save}" Click="Save_Click" />
        </StackPanel>
    </Grid>

</Window>
