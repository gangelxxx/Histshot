<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Histshot.Views"
        x:Class="Histshot.Views.EditorWindow"
        Title="Histshot Editor"
        WindowDecorations="None"
        Topmost="True"
        CanResize="False"
        WindowStartupLocation="Manual">
    <Canvas x:Name="RootCanvas" ClipToBounds="False">
        <views:EditorControl x:Name="Editor" />
        <views:ToolbarControl x:Name="Toolbar"
                              Canvas.Left="0"
                              Canvas.Top="0" />
    </Canvas>
</Window>
